    "Dialogue.Regla.Resort": "",
    "Dialogue.Regla.Resort_Bar": "",
    "Dialogue.Regla.Resort_Chair": "",
    "Dialogue.Regla.Resort_Dance": "",
    "Dialogue.Regla.Resort_Entering": "",
    "Dialogue.Regla.Resort_Leaving": "",
    "Dialogue.Regla.Resort_Shore": "",
    "Dialogue.Regla.Resort_Towel": "",
