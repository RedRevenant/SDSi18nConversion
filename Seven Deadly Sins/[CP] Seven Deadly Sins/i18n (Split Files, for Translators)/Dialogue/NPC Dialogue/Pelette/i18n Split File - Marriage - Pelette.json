{
      /* [Dialogue] Pelette (Marriage) */
      /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
      //[Pelette (Marriage) Dialogue] Special
      "Dialogue.Pelette.Marriage.patio_Pelette": "月色很好，呃...下一句应该说什么来着。$4#$b#我也爱你。$13",
      "Dialogue.Pelette.Marriage.jobLeave_Pelette": "要出门吗？注意安全，搞不定的事情可以回来喊我。$1",
      "Dialogue.Pelette.Marriage.funLeave_Pelette": "路上小心，我会在家等你的。$1",
      "Dialogue.Pelette.Marriage.jobReturn_Pelette": "怎么了吗？$1",
      "Dialogue.Pelette.Marriage.funReturn_Pelette": "需要我帮忙？$1",
      "Dialogue.Pelette.Marriage.spouseRoom_Pelette": "我的房间比较小，破掉的地方我已经提前修好了。不用担心。$1#$b#东西我也会自己整理好的，健身器材放在这边不会碍事吧？$6#$b#这个花瓶...以后可以摆些你喜欢的花。$1",
      /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
      //[Pelette (Marriage) Dialogue] Rainy
      "Dialogue.Pelette.Marriage.Rainy_Day_0": "淋雨并不是件好事，容易生病，衣服湿漉漉的感觉也会让人感到不适。$2#$q 18000804/18000805/18000806 Rainy_Day_0_P1old#……#$r 18000804 0 Rainy_Day_0_18000804#感觉身上黏糊糊的。#$r 18000805 0 Rainy_Day_0_18000805#就这一次。#$r 18000806 0 Rainy_Day_18000806#一起来淋雨。",
      "Dialogue.Pelette.Marriage.Rainy_Day_1": "今天也打算出门吗？多穿些衣服，别冻着了。$1#$q 18000807/18000808/18000809 Rainy_Day_1_P1old#……#$r 18000807 0 Rainy_Day_1_18000807#出门。#$r 18000808 0 Rainy_Day_1_18000808#不出门。#$r 18000809 0 Rainy_Day_1_18000809#我知道了。",
      "Dialogue.Pelette.Marriage.Rainy_Day_2": "至少今天不需要给需要给农田浇水了。$1#$q 18000810/18000811/18000812 Rainy_Day_2_P1old#……#$r 18000810 0 Rainy_Day_2_18000810#偷懒一天。#$r 18000811 0 Rainy_Day_2_18000811#房间里的花还需要浇水。#$r 18000812 0 Rainy_Day_2_18000812#要是天天这样就好了。",
      "Dialogue.Pelette.Marriage.Rainy_Day_3": "很少有花朵能在大雨中存活下来吧？$2#$q 18000813/18000814/18000815 Rainy_Day_3_P1old#……#$r 18000813 0 Rainy_Day_3_18000813#不一定。#$r 18000814 0 Rainy_Day_3_18000814#很少。#$r 18000815 0 Rainy_Day_3_18000815#我们可以保护它。",
      "Dialogue.Pelette.Marriage.Rainy_Day_4": "如果没什么急事，今天就别出门了。$2#$q 18000816/18000817/18000818 Rainy_Day_4_P1old#……#$r 18000816 0 Rainy_Day_4_18000816#好。#$r 18000817 0 Rainy_Day_4_18000817#雨不大。#$r 18000818 0 Rainy_Day_4_18000818#有急事要出门。",
      /*~*~*~*/
      "Dialogue.Pelette.Marriage.Rainy_Night_0": "看你冻得像只鹌鹑...不，我没有笑你的意思。*忍笑*$1#$q 18000819/18000820/18000821 Rainy_Night_0_P1old#……#$r 18000819 0 Rainy_Night_0_18000819#好冷啊。#$r 18000820 0 Rainy_Night_0_18000820#才没有。#$r 18000821 0 Rainy_Night_18000821#我看到你笑了。",
      "Dialogue.Pelette.Marriage.Rainy_Night_1": "你害怕打雷吗？$6#$q 18000822/18000823 Rainy_Night_1_P1old#……#$r 18000822 0 Rainy_Night_1_18000822#害怕。#$r 18000823 0 Rainy_Night_1_18000823#不害怕。",
      "Dialogue.Pelette.Marriage.Rainy_Night_2": "你也忙了一天，去洗个热水澡暖暖。$1#$q 18000824/18000825/18000826 Rainy_Night_2_P1old#……#$r 18000824 0 Rainy_Night_2_18000824#我知道了。#$r 18000825 0 Rainy_Night_2_18000825#你要洗吗？#$r 18000826 0 Rainy_Night_2_18000826#要一起洗吗？",
      "Dialogue.Pelette.Marriage.Rainy_Night_3": "怎么了？$6#$q 18000827/18000828/18000829 Rainy_Night_3_P1old#……#$r 18000827 0 Rainy_Night_3_18000827#你的头发湿掉了。#$r 18000828 0 Rainy_Night_3_18000828#晚上一起睡吧。#$r 18000829 0 Rainy_Night_3_18000829#没什么。",
      "Dialogue.Pelette.Marriage.Rainy_Night_4": "不用你帮我擦头发，我自己来就好。$4#$q 18000830/18000831/18000832 Rainy_Night_4_P1old#……#$r 18000830 0 Rainy_Night_4_18000830#擦不干净的，我帮你。#$r 18000831 0 Rainy_Night_4_18000831#你可以多依赖我一些。#$r 18000832 0 Rainy_Night_4_18000832#好吧。",
      "Dialogue.Pelette.Marriage.Rainy_Night_5": "明天一块出门吧，雨后的空气不错的。$1#$q 18000833/18000834/18000835 Rainy_Night_5_P1old#……#$r 18000833 0 Rainy_Night_5_18000833#好啊。#$r 18000834 0 Rainy_Night_5_18000834#再窝在家里一天。#$r 18000835 0 Rainy_Night_5_18000835#你知道为什么雨后空气好吗？",
      /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
      //[Pelette (Marriage) Dialogue] Indoor
      "Dialogue.Pelette.Marriage.Indoor_Day_0": "今天有出门的打算吗？$1#$q 18000836/18000837 Indoor_Day_0_P1old#……#$r 18000836 0 Indoor_Day_0_18000836#有。#$r 18000837 0 Indoor_Day_0_18000837#没有。",
      "Dialogue.Pelette.Marriage.Indoor_Day_1": "下厨？我的厨艺或许要让你失望了。$2#$q 18000838/18000839/18000840 Indoor_Day_1_P1old#……#$r 18000838 0 Indoor_Day_1_18000838#没关系。#$r 18000839 0 Indoor_Day_1_18000839#我陪你做。#$r 18000840 0 Indoor_Day_1_18000840#我可以给你做。",
      "Dialogue.Pelette.Marriage.Indoor_Day_2": "有时候在家里总感觉能避免一些讨厌的视线。$0#$q 18000841/18000842/18000843 Indoor_Day_2_P1old#……#$r 18000841 0 Indoor_Day_2_18000841#什么视线。#$r 18000842 0 Indoor_Day_2_18000842#有门挡着呢。#$r 18000843 0 Indoor_Day_2_18000843#有我在呢。",
      "Dialogue.Pelette.Marriage.Indoor_Day_3": "在家里有些无事可做，我又不想看书。$2#$q 18000844/18000845/18000846 Indoor_Day_3_P1old#……#$r 18000844 0 Indoor_Day_3_18000844#为什么不想看书。#$r 18000845 0 Indoor_Day_3_18000845#看看电视？#$r 18000846 0 Indoor_Day_3_18000846#陪我出门吧。",
      "Dialogue.Pelette.Marriage.Indoor_Day_4": "花放在客厅了。$1#$q 18000847/18000848 Indoor_Day_4_P1old#……#$r 18000847 0 Indoor_Day_4_18000847#我知道了。#$r 18000848 0 Indoor_Day_4_18000848#什么花。",
      /*~*~*~*/
      "Dialogue.Pelette.Marriage.Indoor_Night_0": "运动结束之后收好汗我就去洗澡。$1#$q 18000849/18000850/18000851 Indoor_Night_0_P1old#……#$r 18000849 0 Indoor_Night_0_18000849#我也想运动。#$r 18000850 0 Indoor_Night_0_18000850#我帮你收器械。#$r 18000851 0 Indoor_Night_18000851#为什么不能直接洗。",
      "Dialogue.Pelette.Marriage.Indoor_Night_1": "今天过得怎么样，如果被哪个蠢蛋欺负了一定要告诉我。$3#$q 18000852/18000853/18000854 Indoor_Night_1_P1old#……#$r 18000852 0 Indoor_Night_1_18000852#过得不错。#$r 18000853 0 Indoor_Night_1_18000853#还可以。#$r 18000854 0 Indoor_Night_1_18000854#有讨厌的人。",
      "Dialogue.Pelette.Marriage.Indoor_Night_2": "外面乌漆嘛黑的，出门都能被石头绊个跟头。$7#$q 18000855/18000856/18000857 Indoor_Night_2_P1old#……#$r 18000855 0 Indoor_Night_2_18000855#我就被绊了。#$r 18000856 0 Indoor_Night_2_18000856#院子里有很多石头。#$r 18000857 0 Indoor_Night_2_18000857#别在黑天出门。",
      "Dialogue.Pelette.Marriage.Indoor_Night_3": "你有记得给农田浇水吗？$1#$q 18000858/18000859/18000860 Indoor_Night_3_P1old#……#$r 18000858 0 Indoor_Night_3_18000858#记得。#$r 18000859 0 Indoor_Night_3_18000859#忘了。#$r 18000860 0 Indoor_Night_3_18000860#有自动浇水器。",
      "Dialogue.Pelette.Marriage.Indoor_Night_4": "该睡觉了，难不成你需要助眠的故事？$1#$q 18000861/18000862 Indoor_Night_4_P1old#……#$r 18000861 0 Indoor_Night_4_18000861#需要。#$r 18000862 0 Indoor_Night_4_18000862#不需要。",
      "Dialogue.Pelette.Marriage.Indoor_Night_5": "我今天过得很开心，可能是你陪在身边吧。晚安。$13#$q 18000863/18000864/18000865 Indoor_Night_5_P1old#……#$r 18000863 0 Indoor_Night_5_18000863#我也很开心。#$r 18000864 0 Indoor_Night_5_18000864#明天也会如此。#$r 18000865 0 Indoor_Night_5_18000865#晚安。",
      /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
      //[Pelette (Marriage) Dialogue] Outdoor
      "Dialogue.Pelette.Marriage.Outdoor_0": "因为常年待在那冷的要死的地方，温暖的太阳都变得难得了。$1#$q 18000866/18000867/18000868 Outdoor_0_P1old#……#$r 18000866 0 Outdoor_0_18000866#多出来走走吧。#$r 18000867 0 Outdoor_0_18000867#辛苦了。#$r 18000868 0 Outdoor_18000868#那边没有太阳吗？",
      "Dialogue.Pelette.Marriage.Outdoor_1": "你也出来了？你是应该多出门走走。$1#$q 18000869/18000870/18000871 Outdoor_1_P1old#……#$r 18000869 0 Outdoor_1_18000869#你在做什么。#$r 18000870 0 Outdoor_1_18000870#我有事要出门。#$r 18000871 0 Outdoor_1_18000871#所以我出门了。",
      "Dialogue.Pelette.Marriage.Outdoor_2": "多出门走走对身体好。$1#$q 18000872/18000873/18000874 Outdoor_2_P1old#……#$r 18000872 0 Outdoor_2_18000872#我知道了。#$r 18000873 0 Outdoor_2_18000873#一起逛逛？#$r 18000874 0 Outdoor_2_18000874#我累了。",
      "Dialogue.Pelette.Marriage.Outdoor_3": "既然碰到了就一块走走吧，遛弯结束可以一起回家。$1#$q 18000875/18000876/18000877 Outdoor_3_P1old#……#$r 18000875 0 Outdoor_3_18000875#你要去做什么？#$r 18000876 0 Outdoor_3_18000876#好啊。#$r 18000877 0 Outdoor_3_18000877#我打算回家了。",
      "Dialogue.Pelette.Marriage.Outdoor_4": "你是来找我的还是碰巧路过？$4#$q 18000878/18000879/18000880 Outdoor_4_P1old#……#$r 18000878 0 Outdoor_4_18000878#来找你。#$r 18000879 0 Outdoor_4_18000879#碰巧路过。#$r 18000880 0 Outdoor_4_18000880#你猜？",
      /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
      //[Pelette (Marriage) Dialogue] Kids
      "Dialogue.Pelette.Marriage.OneKid_0": "以前我面对的都是死亡，从来没这么真切的感受过生命的诞生。$6#$q 18000881/18000882/18000883 OneKid_0_P1old#……#$r 18000881 0 OneKid_0_18000881#做父亲的感觉怎么样。#$r 18000882 0 OneKid_0_18000882#人生除了死亡还有新生。#$r 18000883 0 OneKid_0_18000883#来抱抱他吧。",
      "Dialogue.Pelette.Marriage.OneKid_1": "呃...我还是很不适应孩子的吵闹声，我已经在忍着不发火了。$7#$q 18000884/18000885/18000886 OneKid_1_P1old#……#$r 18000884 0 OneKid_1_18000884#消消气。#$r 18000885 0 OneKid_1_18000885#不可以跟小孩子生气。#$r 18000886 0 OneKid_1_18000886#确实很吵。",
      "Dialogue.Pelette.Marriage.OneKid_2": "喂!把东西放下。$3#$b#不是...我没有在说你。$6#$q 18000887/18000888/18000889 OneKid_2_P1old#……#$r 18000887 0 OneKid_2_18000887#在说谁？#$r 18000888 0 OneKid_2_18000888#在说孩子？#$r 18000889 0 OneKid_2_18000889#把东西放下！",
      "Dialogue.Pelette.Marriage.OneKid_3": "我还以为我平时凶到让孩子不愿意靠近，结果他倒是像块膏药一样黏上来。$6#$q 18000890/18000891/18000892 OneKid_3_P1old#……#$r 18000890 0 OneKid_3_18000890#没有很凶。#$r 18000891 0 OneKid_3_18000891#孩子很喜欢你。#$r 18000892 0 OneKid_3_18000892#你小时候也这样吗？",
      "Dialogue.Pelette.Marriage.OneKid_4": "我会尽量去做个好父亲的，起码不会让其他人再我经历的恶心事。$1#$b#但我希望我的孩子也能做个像恩人那时一样优秀的孩子。$1#$q 18000893/18000894/18000895 OneKid_4_P1old#……#$r 18000893 0 OneKid_4_18000893#会的。#$r 18000894 0 OneKid_4_18000894#他开心就好。#$r 18000895 0 OneKid_4_18000895#我会陪你教导他。",
      /*~*~*~*/
      "Dialogue.Pelette.Marriage.TwoKids_0": "吵闹的家伙又增加了...$7#$q 18000896/18000897/18000898 TwoKids_0_P1old#……#$r 18000896 0 TwoKids_0_18000896#喜欢吗？#$r 18000897 0 TwoKids_0_18000897#很烦吗？#$r 18000898 0 TwoKids_0_18000898#俩个孩子很吵！",
      "Dialogue.Pelette.Marriage.TwoKids_1": "不过每次看这两个家伙都会让我想起以前的事。$0#$q 18000899/18000900/18000901 TwoKids_1_P1old#……#$r 18000899 0 TwoKids_1_18000899#怀念吗？#$r 18000900 0 TwoKids_1_18000900#以前的事？#$r 18000901 0 TwoKids_1_18000901#珍惜现在。",
      "Dialogue.Pelette.Marriage.TwoKids_2": "年纪小的孩子也要学着照顾年长的另一位。$0#$q 18000902/18000903/18000904 TwoKids_2_P1old#……#$r 18000902 0 TwoKids_2_18000902#在教小孩子吗？#$r 18000903 0 TwoKids_2_18000903#你说得对。#$r 18000904 0 TwoKids_2_18000904#我们呢？",
      "Dialogue.Pelette.Marriage.TwoKids_3": "不知道他们俩个小孩里有没有人会喜欢花。$1#$q 18000905/18000906 TwoKids_3_P1old#……#$r 18000905 0 TwoKids_3_18000905#有。#$r 18000906 0 TwoKids_3_18000906#没有。",
      "Dialogue.Pelette.Marriage.TwoKids_4": "我大概快习惯小孩的叽叽喳喳乱叫的样子了。$1#$q 18000907/18000908/18000909 TwoKids_4_P1old#……#$r 18000907 0 TwoKids_4_18000907#我也是。#$r 18000908 0 TwoKids_4_18000908#我还没有。#$r 18000909 0 TwoKids_4_18000909#为什么。",
      /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
      //[Pelette (Marriage) Dialogue] Good
      "Dialogue.Pelette.Marriage.Good_0": "待在你身边的时候总能感觉安心许多。$1#$q 18000910/18000911/18000912 Good_0_P1old#……#$r 18000910 0 Good_0_18000910#真的吗？#$r 18000911 0 Good_0_18000911#我也一样。#$r 18000912 0 Good_0_18000912#那就一直待在一起吧。",
      "Dialogue.Pelette.Marriage.Good_1": "要摸摸呸呸吗？$1#$q 18000913/18000914/18000915 Good_1_P1old#……#$r 18000913 0 Good_1_18000913#要！#$r 18000914 0 Good_1_18000914#怕它咬我。#$r 18000915 0 Good_1_18000915#（摸摸佩莱特）",
      "Dialogue.Pelette.Marriage.Good_2": "你太瘦弱了，跟我一块跑两圈吧。$1#$q 18000916/18000917/18000918 Good_2_P1old#……#$r 18000916 0 Good_2_18000916#好。#$r 18000917 0 Good_2_18000917#不要。#$r 18000918 0 Good_2_18000918#我不瘦。",
      "Dialogue.Pelette.Marriage.Good_3": "我也知道很多话不能直接说，因为行动是更有力的。$4#$q 18000919/18000920/18000921 Good_3_P1old#……#$r 18000919 0 Good_3_18000919#从什么时候开始的。#$r 18000920 0 Good_3_18000920#我也喜欢这样。#$r 18000921 0 Good_3_18000921#比如？",
      "Dialogue.Pelette.Marriage.Good_4": "这是我常喝的酒，要一块喝吗？$1#$q 18000922/18000923/18000924 Good_4_P1old#……#$r 18000922 0 Good_4_18000922#要。#$r 18000923 0 Good_4_18000923#我不喝酒。#$r 18000924 0 Good_4_18000924#干杯！",
      "Dialogue.Pelette.Marriage.Good_5": "姐姐，恩人，还有你。都是我最重要的人。$1#$q 18000925/18000926 Good_5_P1old#……#$r 18000925 0 Good_5_18000925#你也是我重要的人。#$r 18000926 0 Good_5_18000926#以后的日子也这样度过吧。",
      "Dialogue.Pelette.Marriage.Good_6": "帮你挑选衣服的颜色？嗯...粉色？$6#$q 18000927/18000928/18000929 Good_6_P1old#……#$r 18000927 0 Good_6_18000927#真的吗？#$r 18000928 0 Good_6_18000928#我也喜欢粉色。#$r 18000929 0 Good_6_18000929#你喜欢什么颜色？",
      "Dialogue.Pelette.Marriage.Good_7": "想和你一块去买花。$1#$q 18000930/18000931/18000932 Good_7_P1old#……#$r 18000930 0 Good_7_18000930#钱花完了。#$r 18000931 0 Good_7_18000931#你想买什么花？#$r 18000932 0 Good_7_18000932#我来选买什么花。",
      "Dialogue.Pelette.Marriage.Good_8": "你喜欢什么地方，我想带你去约会。$1#$q 18000933/18000934/18000935 Good_8_P1old#……#$r 18000933 0 Good_8_18000933#花园。#$r 18000934 0 Good_8_18000934#海边。#$r 18000935 0 Good_8_18000935#怎么直接说出来了。",
      "Dialogue.Pelette.Marriage.Good_9": "一块买一些花来摆着吧，好看。$1#$b#%他见你过来，几乎不可闻地轻笑了一声。#$q 18000936/18000937/18000938 Good_9_P1old#……#$r 18000936 0 Good_9_18000936#你喜欢什么花。#$r 18000937 0 Good_9_18000937#好啊。#$r 18000938 0 Good_9_18000938#见我过来这么开心啊。",
      /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
      //[Pelette (Marriage) Dialogue] Neutral
      "Dialogue.Pelette.Marriage.Neutral_0": "晚饭吃什么都行，我早就习惯随便吃了。$1#$q 18000939/18000940/18000941 Neutral_0_P1old#……#$r 18000939 0 Neutral_0_18000939#蛋包饭。#$r 18000940 0 Neutral_0_18000940#蛋糕。#$r 18000941 0 Neutral_0_18000941#米饭。",
      "Dialogue.Pelette.Marriage.Neutral_1": "讨厌的东西...$7#$q 18000942/18000943 Neutral_1_P1old#……#$r 18000942 0 Neutral_1_18000942#怎么了。#$r 18000943 0 Neutral_1_18000943#你讨厌什么。",
      "Dialogue.Pelette.Marriage.Neutral_2": "别总在衣服堆里挑来挑去了，不都差不多吗？$6#$q 18000944/18000945/18000946 Neutral_2_P1old#……#$r 18000944 0 Neutral_2_18000944#都一样？#$r 18000945 0 Neutral_2_18000945#一定要选件最好看的。#$r 18000946 0 Neutral_2_18000946#嫌我磨蹭了吗？",
      "Dialogue.Pelette.Marriage.Neutral_3": "妈的...这些事就不能直接弄得简单些吗？$3#$q 18000947/18000948/18000949 Neutral_3_P1old#……#$r 18000947 0 Neutral_3_18000947#怎么了。#$r 18000948 0 Neutral_3_18000948#确实麻烦。#$r 18000949 0 Neutral_3_18000949#别生气了。",
      "Dialogue.Pelette.Marriage.Neutral_4": "我种菜种不活的，如果你不介意，我能帮忙。$1#$q 18000950/18000951/18000952 Neutral_4_P1old#……#$r 18000950 0 Neutral_4_18000950#我不介意。#$r 18000951 0 Neutral_4_18000951#你休息就好。#$r 18000952 0 Neutral_4_18000952#真的种不活吗？",
      "Dialogue.Pelette.Marriage.Neutral_5": "%他正整理着一束鲜花。#$q 18000953/18000954 Neutral_5_P1old#……#$r 18000953 0 Neutral_5_18000953#哪来的。#$r 18000954 0 Neutral_5_18000954#（悄悄过去吓他）",
      "Dialogue.Pelette.Marriage.Neutral_6": "要跟我一块运动吗？你可以从比较轻的杠铃开始。$1#$q 18000955/18000956/18000957 Neutral_6_P1old#……#$r 18000955 0 Neutral_6_18000955#好。#$r 18000956 0 Neutral_6_18000956#不要。#$r 18000957 0 Neutral_6_18000957#我可以直接抬重的。",
      "Dialogue.Pelette.Marriage.Neutral_7": "我一直以来都很感谢我的恩人，希望我在以后对他也能有帮助。$1#$q 18000958/18000959 Neutral_7_P1old#……#$r 18000958 0 Neutral_7_18000958#会的。#$r 18000959 0 Neutral_7_18000959#继续努力。",
      "Dialogue.Pelette.Marriage.Neutral_8": "我去弄了些食物给呸呸。$1#$q 18000960/18000961/18000962 Neutral_8_P1old#……#$r 18000960 0 Neutral_8_18000960#我也要去。#$r 18000961 0 Neutral_8_18000961#早去早回。#$r 18000962 0 Neutral_8_18000962#食物？",
      "Dialogue.Pelette.Marriage.Neutral_9": "在做什么，我帮你。$1#$q 18000963/18000964/18000965 Neutral_9_P1old#……#$r 18000963 0 Neutral_9_18000963#浇花。#$r 18000964 0 Neutral_9_18000964#买东西。#$r 18000965 0 Neutral_9_18000965#没做什么。",
      /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
      //[Pelette (Marriage) Dialogue] Bad
      "Dialogue.Pelette.Marriage.Bad_0": "是最近发生了什么吗？$2#$q 18000966/18000967 Bad_0_P1old#……#$r 18000966 0 Bad_0_18000966#没有#$r 18000967 0 Bad_0_18000967#我心情不好。",
      "Dialogue.Pelette.Marriage.Bad_1": "我做错什么了吗？$2#$q 18000968/18000969/18000970 Bad_1_P1old#……#$r 18000968 0 Bad_1_18000968#没有。#$r 18000969 0 Bad_1_18000969#是的。#$r 18000970 0 Bad_1_18000970#我不知道。",
      "Dialogue.Pelette.Marriage.Bad_2": "我们还可以再谈谈吗？$2#$q 18000971/18000972/18000973 Bad_2_P1old#……#$r 18000971 0 Bad_2_18000971#可以。#$r 18000972 0 Bad_2_18000972#不要。#$r 18000973 0 Bad_2_18000973#... ...",
      "Dialogue.Pelette.Marriage.Bad_3": "你累了吗？$6#$q 18000974/18000975/18000976 Bad_3_P1old#……#$r 18000974 0 Bad_3_18000974#还好。#$r 18000975 0 Bad_3_18000975#累了。#$r 18000976 0 Bad_3_18000976#... ...",
      "Dialogue.Pelette.Marriage.Bad_4": "能干的活我已经帮你干了，没什么事我就先走了。$0#$q 18000977/18000978/18000979 Bad_4_P1old#……#$r 18000977 0 Bad_4_18000977#... ...#$r 18000978 0 Bad_4_18000978#你去哪？#$r 18000979 0 Bad_4_18000979#不需要。",
      "Dialogue.Pelette.Marriage.Bad_5": "%他的目光看向别处，没有直视了你在的方向。#$q 18000980/18000981 Bad_5_P1old#……#$r 18000980 0 Bad_5_18000980#喂。#$r 18000981 0 Bad_5_18000981#......",
      "Dialogue.Pelette.Marriage.Bad_6": "... ...$3#$q 18000982/18000983/18000984 Bad_6_P1old#……#$r 18000982 0 Bad_6_18000982#... ...#$r 18000983 0 Bad_6_18000983#你好。#$r 18000984 0 Bad_6_18000984#听我解释。",
      "Dialogue.Pelette.Marriage.Bad_7": "%他换了个方向走了。#$q 18000985/18000986 Bad_7_P1old#……#$r 18000985 0 Bad_7_18000985#（离开）#$r 18000986 0 Bad_7_18000986#（跟上去）",
      "Dialogue.Pelette.Marriage.Bad_8": "怎么了...$0#$q 18000987/18000988/18000989 Bad_8_P1old#……#$r 18000987 0 Bad_8_18000987#听我解释。#$r 18000988 0 Bad_8_18000988#......#$r 18000989 0 Bad_8_18000989#（离开）",
      "Dialogue.Pelette.Marriage.Bad_9": "嗯...#$q 18000990/18000991/18000992 Bad_9_P1old#……#$r 18000990 0 Bad_9_18000990#怎么了吗？#$r 18000991 0 Bad_9_18000991#... ...#$r 18000992 0 Bad_9_18000992#我可以解释。",
      /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
      //[Pelette (Marriage) Dialogue] Holiday
      "Dialogue.Pelette.Marriage.spring_1": "温暖的日子开始了，没了冰冷的空气还是有些怀念。$1#$b#嗯...新年快乐。$1#$q 18000993/18000994/18000995 spring_1_P1old#……#$r 18000993 0 spring_1_18000993#新年快乐！#$r 18000994 0 spring_1_18000994#可以许愿吗？#$r 18000995 0 spring_1_18000995#今年有什么打算。",
      "Dialogue.Pelette.Marriage.spring_12": "明天就是那个在那钻来钻去跟小孩老头抢鸡蛋的日子了。$6#$b#你要去吗？$1#$q 18000996/18000997/18000998 spring_12_P1old#……#$r 18000996 0 spring_12_18000996#鸡蛋？#$r 18000997 0 spring_12_18000997#要去。#$r 18000998 0 spring_12_18000998#才不是和他们抢鸡蛋。",
      "Dialogue.Pelette.Marriage.spring_23": "外面到处飘着花瓣，明天是那个要跳舞的节日？$1#$q 18000999/18001000/18001001 spring_23_P1old#……#$r 18000999 0 spring_23_18000999#你会陪我跳舞吗？#$r 18001000 0 spring_23_18001000#外面飘着的花瓣很美。#$r 18001001 0 spring_23_18001001#明天就是花舞节了。",
      "Dialogue.Pelette.Marriage.summer_1": "天气开始热起来了，怪不得总有人说炎热和寒冷同样可怕。$6#$q 18001002/18001003/18001004 summer_1_P1old#……#$r 18001002 0 summer_1_18001002#可以吃冰淇淋了。#$r 18001003 0 summer_1_18001003#可以穿凉快的衣服了。#$r 18001004 0 summer_1_18001004#我更怕寒冷。",
      "Dialogue.Pelette.Marriage.summer_10": "所有人往汤里放一样食物...？听起来像是行军没有粮食时候的无奈选择。$7#$q 18001005/18001006/18001007 summer_10_P1old#……#$r 18001005 0 summer_10_18001005#你们也这样吗？#$r 18001006 0 summer_10_18001006#你会加什么？#$r 18001007 0 summer_10_18001007#我要加我最喜欢的食物。",
      "Dialogue.Pelette.Marriage.summer_28": "你喜欢那些亮闪闪的水母？我可以帮你抓来。$1#$q 18001008/18001009/18001010 summer_28_P1old#……#$r 18001008 0 summer_28_18001008#它们还是在海里好看。#$r 18001009 0 summer_28_18001009#它们要回家的。#$r 18001010 0 summer_28_18001010#我想要那只。",
      "Dialogue.Pelette.Marriage.fall_1": "这些树叶一下子全黄了，很快就会秃了。$2#$q 18001011/18001012/18001013 fall_1_P1old#……#$r 18001011 0 fall_1_18001011#我想捡几片树叶做书签。#$r 18001012 0 fall_1_18001012#那是冬天的事了。#$r 18001013 0 fall_1_18001013#但同时秋天会有很多果实。",
      "Dialogue.Pelette.Marriage.fall_15": "展览中有些的东西我还是认识的。$1#$q 18001014/18001015/18001016 fall_15_P1old#……#$r 18001014 0 fall_15_18001014#比如？#$r 18001015 0 fall_15_18001015#我喜欢那些矿石。#$r 18001016 0 fall_15_18001016#我带你去逛。",
      "Dialogue.Pelette.Marriage.fall_26": "外面有些人扮成妖怪了，真奇怪。$6#$q 18001017/18001018/18001019 fall_26_P1old#……#$r 18001017 0 fall_26_18001017#我也要去扮幽灵妖怪了。#$r 18001018 0 fall_26_18001018#那是节日的特色。#$r 18001019 0 fall_26_18001019#你要试试吗？",
      "Dialogue.Pelette.Marriage.winter_1": "今早有雪花落在窗前了。$1#$q 18001020/18001021/18001022 winter_1_P1old#……#$r 18001020 0 winter_1_18001020#一起喝一杯来庆祝冬天的到来吧。#$r 18001021 0 winter_1_18001021#想和你看今年的第一场雪。#$r 18001022 0 winter_1_18001022#世界上没有两片相同的雪花。",
      "Dialogue.Pelette.Marriage.winter_7": "我们曾经也会在这样的时候去冬泳。$1#$q 18001023/18001024/18001025 winter_7_P1old#……#$r 18001023 0 winter_7_18001023#可是这是要钓鱼的日子。#$r 18001024 0 winter_7_18001024#不冷吗？#$r 18001025 0 winter_7_18001025#我也想试试。",
      "Dialogue.Pelette.Marriage.winter_23": "这些装饰是你买来的吗？$6#$q 18001026/18001027/18001028 winter_23_P1old#……#$r 18001026 0 winter_23_18001026#是我买的。#$r 18001027 0 winter_23_18001027#好看吗？#$r 18001028 0 winter_23_18001028#冬日星快乐——",
      "Dialogue.Pelette.Marriage.winter_28": "柴火都是充足的，汤也是热的...$1#$q 18001029/18001030/18001031 winter_28_P1old#……#$r 18001029 0 winter_28_18001029#在做什么？#$r 18001030 0 winter_28_18001030#还有一场浪漫的飞雪。#$r 18001031 0 winter_28_18001031#一起裹上毯子喝一口热汤吧。"
      /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
      /*-----------------------------------------------------------------------------------------------------------*/
}