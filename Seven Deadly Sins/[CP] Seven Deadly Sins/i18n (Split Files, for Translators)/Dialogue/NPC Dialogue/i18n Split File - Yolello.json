{
  /* [Dialogue] Yolello */
  /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
  //[Yolello Dialogue] Special
  "Dialogue.Yolello.Introduction": "……#$b#这里真是个偏僻的地方，就连农夫都一副令人不愉快的样子。#$b#说什么自我介绍也只是场面话罢了，我是约莱洛，没其他事情请不要挡在我前面。",
  "Dialogue.Yolello.joja_Begin": "JOJA，或许那样的地方很适合你。#$b#毕竟他们一定很需要一个勤勉的人。$1",
  "Dialogue.Yolello.movieTheater": "电影院或许是这座小镇仅剩的放松方式了吧。#$b#遗憾的是我对电影没什么兴趣。",
  "Dialogue.Yolello.MovieInvitation": "正好我有时间，那么便陪你一起去看看这无聊的消遣方式吧。$1",
  /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
  //[Yolello Dialogue] Rejection
  "Dialogue.Yolello.danceRejection": "我为什么要和你跳舞？少做这种浪费体力的事情。#$b#我讨厌闲人啊。$3",
  "Dialogue.Yolello.rejectNPCA": "如果想要丢垃圾的话不建议给我。",
  "Dialogue.Yolello.rejectNPCB": "我果然不能理解像你这种愚蠢的家伙在想什么。",
  "Dialogue.Yolello.reject_two_heartA": "可悲的家伙……像你这样的人别再靠近我了。",
  "Dialogue.Yolello.reject_two_heartB": "少拿这种奇怪的东西给我。",
  "Dialogue.Yolello.reject_four_heartA": "你并不缺少来自其他人的爱，但那些人里并不会有我。",
  "Dialogue.Yolello.reject_four_heartB": "试想一下，一个被所有人爱慕的家伙却唯独递给了你花束，你认为会是什么下场？#$b#开玩笑也要有个限度吧？$3",
  "Dialogue.Yolello.engageA": "看起来我的消息已经落后了，你什么时候取消的订婚？",
  "Dialogue.Yolello.engageB": "最近镇子上的人都在流传你要订婚了，你想在结婚前找一个合适的地下情人？#$b#开什么玩笑，愚蠢至极。$3",
  "Dialogue.Yolello.marriedA": "你什么时候离的婚？",
  "Dialogue.Yolello.marriedB": "你有没有去找医生看过你的大脑？至少现在我认为它不存在你那可悲的头颅内。$3",
  "Dialogue.Yolello.refusal_known": "……",
  "Dialogue.Yolello.refusal_bother": "开什么玩笑，我受够了。$3",
  "Dialogue.Yolello.refusal_no_hearts": "我的佩剑并没有像AMELE前辈那样遗失，这意味着我可以随时挥剑。",
  /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
  //[Yolello Dialogue] General/Spring
  "Dialogue.Yolello.Mon": "真是散漫的家伙，老老实实做你的工作就好了。",
  "Dialogue.Yolello.Tue": "你并不是看起来那么忙碌啊，散漫是成为闲人的第一步。#$b#这样下去大脑也会退化吧。",
  "Dialogue.Yolello.Wed": "我不会和看起来没价值的人进行太多对话的，不如去找些活干吧？",
  "Dialogue.Yolello.Thu": "AMELE前辈跑到什么地方去了，我还想向他请教一下剑术……$2#$b#哈……别挡路好吗？@。$3",
  "Dialogue.Yolello.Fri": "态度是因人而异的，没有价值的人需要怎样的好态度？",
  "Dialogue.Yolello.Sat": "我对散漫的闲人通常没什么记忆，但你是否过于闲暇了？#$b#你没有要做的事情吗？$3",
  "Dialogue.Yolello.Sun": "按理说我不应该回应你，但这样会给人留下更坏的印象。#$b#那样就太过于显眼了。",
  /*~*~*~*/
  "Dialogue.Yolello.Mon2": "对待不熟的人需要怎样的态度？#$b#喜欢和好态度的人交流建议别来找我。",
  "Dialogue.Yolello.Tue2": "我比你要更加忙碌，没时间去管理那些无聊的事情。#$b#作为农夫你不应该比我一个骑士更忙？",
  "Dialogue.Yolello.Wed2": "等等，我需要安静#$b#有什么事情你可以说，但我能不能听进去是另一回事。",
  "Dialogue.Yolello.Thu2": "酒吧那边好像有打折活动……？#$b#先记录下来吧，说不定能去一趟。$1",
  "Dialogue.Yolello.Fri2": "别吵，安静待着也是与人的一种交流方式。#$b#在我看来大部分事情都没必要进行。",
  "Dialogue.Yolello.Sat2": "镇子上有位医生不是吗？我应该去找他看看。#$b#不然怎么治疗我看见你就头痛的病症。",
  "Dialogue.Yolello.Sun2": "态度转变是需要时间的，但对于你我感觉没这个必要。#$b#如果真要对现在的你有良好态度那我可能是疯了。",
  /*~*~*~*/
  "Dialogue.Yolello.Mon4": "终于勤勉一些了吗？#$b#人类果然还是要多活动才不会导致大脑退化。",
  "Dialogue.Yolello.Tue4": "我对于垃圾和没价值的人没有任何兴趣，那种人最终会消失在世界上，也没人会记得那群人的存在。#$b#勤勉起来不是对所有人都有好处吗？",
  "Dialogue.Yolello.Wed4": "一个忠告，作为你最近勤勉的一个提醒。#$b#多注意周围吧，你难道会不清楚做得越大的企业越会被别人所觊觎吗？#$b#人类还是要带着警惕活下去啊。",
  "Dialogue.Yolello.Thu4": "那个叫JOJA超市的和那个皮埃尔商店真有趣啊……真期待哪个会最先破产呢。$1#$b#这些话会让你不舒服吗？但这是事实不是吗？#$b#哪有两全其美的方法，在这样的一个小镇不需要俩个超市对吧？$1",
  "Dialogue.Yolello.Fri4": "只要人在世界上生活着就需要利益的往来，善良无暇的人只存在古老的童话书籍中。#$b#利益可以让人获得一切。$1",
  "Dialogue.Yolello.Sat4": "没有什么是利益解决不了的，送了礼物不就会收获到对方对你的好感吗？#$b#有的只是利益没到位的礼物罢了。",
  "Dialogue.Yolello.Sun4": "第二个忠告，如果你见到一位黑皮精灵远离他是最好的选择。#$b#离逃犯远点，那家伙容易将人炸的血肉模糊。",
  /*~*~*~*/
  "Dialogue.Yolello.Mon6": "不得不承认你开始变得勤勉了，对于勤勉的人我的态度也不应该再那么差劲。#$b#毕竟对人的转变也是需要时间来熟悉的，初遇就甜言蜜语的家伙难道不应该更警惕些吗？",
  "Dialogue.Yolello.Tue6": "别留存着这里人都是好人这种想法，那个商店的店主不就是个恶劣的家伙吗？#$b#拿着勤勉的人种出的作物称是自己种植的不觉得很可笑吗？#$e#当然，这也是生存手段的其中之一，只要没人揭发他那自认聪明的想法。$1",
  "Dialogue.Yolello.Wed6": "仔细看森林中的话似乎有熟悉的奔跑身影……$3#$b#那个逃犯快活不了太久的。",
  "Dialogue.Yolello.Thu6": "让我来告诉你如何保住现在所拥有的一切如何？#$b#难道你不想对那个店主的谎言做出一些回应吗？揭发他，再做上一些其他的手脚。$1#$b#我能够对你保证你会拥有比他，比JOJA更大的企业，怎么样？#$e#你没有拒绝的理由不是吗？还是说你想与那种虚伪的人继续相处？",
  "Dialogue.Yolello.Fri6": "我不是任何教义的信徒，但我清楚那个祭司在想什么。#$b#靠着自己能够治愈一切的血液来拉拢信徒，这样缺少他血液的人便会无法脱离开他的控制。$1#$b#真是危险的传教人，如此手段也只能对付长期服用他血液的人,还不如求助我帮他的教义走的更长远。$1",
  "Dialogue.Yolello.Sat6": "对待不义的人需要怜悯吗？别惹我发笑了@。#$b#对待那种人耍些手段报复便能够落入深渊，这时你想让他们做什么都可以。#$b#不是很好笑吗？一边乞求着你的原谅一边还在内心想如何去报复你，光是想到那副模样我就要笑出来了。$1",
  "Dialogue.Yolello.Sun6": "那个JOJA超市难道没有对你抛出橄榄枝吗？我还认为他们会需要你这样勤勉的农夫呢。#$b#真是没有商业头脑的一群人啊。$1",
  /*~*~*~*/
  "Dialogue.Yolello.Mon8": "你应该对所有人都警惕些的，无论是站在这里与你交谈的我还是与你交好的其他人。#$b#有时我真的会感慨这里是否过于和平了导致人的警惕性都下降了。",
  "Dialogue.Yolello.Tue8": "我对人或事物都太敏感了吗……？#$b#我的家族靠经商生存，如果不足够警惕或敏感那么倒霉的不就是自己吗？#$b#在商战中不应该保持清醒的头脑吗？$3",
  "Dialogue.Yolello.Wed8": "时间过得可真快，我们竟然也会这样熟络吗？$1#$b#感觉有些不可思议在里面。",
  "Dialogue.Yolello.Thu8": "我对大部分事情都不感兴趣，只有对自己有关的事情会勉强在意一些吧。",
  "Dialogue.Yolello.Fri8": "其他精灵留给你的印象都太好了吗？我本来也不是什么温和的个性。#$b#我只善待对于我有价值，有用处的人。#$b#这种想法没什么能奇怪的吧？又不是所有人都一定要对着第一次见面的人温和。",
  "Dialogue.Yolello.Sat8": "看起来那两家超市的商战有你的介入啊，需要我帮忙吗？$1#$b#如果是我的话我不会帮助任何一家，而是将他们都收做为自己的产业发展。$1#$b#不过JOJA超市似乎是连锁的，只倒闭这一家也不会对他们的整个产业产生什么危害。#$e#怎么样，想让我帮助你将他们的总部也吞并吗？我听说你以前是在那里上班的？$1#$b#这不是很有趣吗？",
  "Dialogue.Yolello.Sun8": "有任何困难可以寻求我的帮助，在商业这部分也许能够帮助到你一些。#$b#当然不会是白帮忙，我之前就说过利益能够驱使人做一切。$1",
  /*~*~*~*/
  "Dialogue.Yolello.Mon10": "我不会做任何骑士宣言的，因为我本质上并不是正直的骑士。#$b#如果你在乎我曾经对你不算友好的态度我会对你致歉，当然，是否原谅的选择权在你手里。$1",
  "Dialogue.Yolello.Tue10": "这里的一些习俗真令人感到奇怪。#$b#不过这也不是我一介过路者该议论的事情，毕竟和我没什么关系。$1",
  "Dialogue.Yolello.Wed10": "闪闪发光的石头这里倒是有很多，如果你有门路也可以卖些给我。$1",
  "Dialogue.Yolello.Thu10": "看你头脑不清醒的样子可能需要一杯茶来令你更清醒一些[614]。#$b#保持头脑清醒不是很重要的事情吗？别忘记了$1",
  "Dialogue.Yolello.Fri10": "你出门难道不注重自己的仪容吗？#$b#嘴角有食物残渣，下次出来记得把脸擦干净。$1",
  "Dialogue.Yolello.Sat10": "手里的钱财到达一定数量后别人的目光可就没那么重要了。$1#$b#所以为了让自己的未来过的舒坦些还是忙碌起来吧？",
  "Dialogue.Yolello.Sun10": "我这里可不是闲散人员用来逃避的地方，现在我要找一个合适的地方来一杯茶清醒头脑。",
  /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
  //[Yolello Dialogue] Summer
  "Dialogue.Yolello.summer_Mon2": "安静点，在这样的热天气还是保持自己身体里的水分比较好。",
  "Dialogue.Yolello.summer_Tue2": "忙你自己的事情，不要与我进行交谈#$b#如果你因为这样的天气而头脑发昏的话，建议你去森林。",
  "Dialogue.Yolello.summer_Wed2": "我不想交谈，这样的天气真令人头痛。",
  "Dialogue.Yolello.summer_Thu4": "我应该去其他地方待上一会，这里很不适合乘凉。",
  "Dialogue.Yolello.summer_Fri4": "这样的天气减少对话次数不是更好吗？在某些方面交谈也挺浪费体力的。",
  "Dialogue.Yolello.summer_Sat4": "你需要一些薄荷糖吗？#$b#清醒头脑不是很重要的事情吗？$1",
  "Dialogue.Yolello.summer_Sun6": "是因为天气太热了吗？那两家超市都消停了许多。$1",
  "Dialogue.Yolello.summer_Mon6": "哈……真讨厌这样的天气，你怎么做到这样还跑来跑去的？",
  "Dialogue.Yolello.summer_Tue6": "嗯？AMELE前辈在海边小屋弹钢琴？#$b#我要去听。$1",
  "Dialogue.Yolello.summer_Wed8": "怎么了？虽然很热但我还是能听你说话的。#$b#打过招呼之后就快离开吧？这个天气很容易中暑。",
  "Dialogue.Yolello.summer_Thu8": "晚上耳边的蝉鸣声真的很吵，在这个地方要适应很多问题真麻烦。",
  "Dialogue.Yolello.summer_Fri8": "这样的小地方都无处可避暑，森林里有虫子我可不想进去。",
  "Dialogue.Yolello.summer_Sat10": "你需要一些薄荷糖吗？#$b#清醒头脑不是很重要的事情吗？$1",
  "Dialogue.Yolello.summer_Sun10": "这里并不流行用戒指求婚啊……这倒也是有趣。$1#$b#其实戒指当作成暗器或许更有价值。$1",
  /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
  //[Yolello Dialogue] Fall
  "Dialogue.Yolello.fall_Mon2": "天气凉了，这种时候真不想四处走动。",
  "Dialogue.Yolello.fall_Tue2": "我没有与你聊天的心情，我现在只想去那般取暖。",
  "Dialogue.Yolello.fall_Wed2": "虽然有AMELE前辈送过来的衣服，但还是很冷。",
  "Dialogue.Yolello.fall_Thu4": "仅仅是秋天就这个天气，到了冬天那还的了……我应该去找一处温暖又不易挨冻的地方。",
  "Dialogue.Yolello.fall_Fri4": "真是令人惊叹的，你都感觉不到这凉下来的天气吗？#$b#我没有去吃什么南瓜派或是野果的兴趣……",
  "Dialogue.Yolello.fall_Sat4": "如果有热茶就好说了，其他能够让身体暖和起来的东西也可以。#$b#去哪里寻找比较好呢？$1",
  "Dialogue.Yolello.fall_Sun6": "四周都是吵闹且无趣的，有这样的时间不如省下体力留着过冬。",
  "Dialogue.Yolello.fall_Mon6": "你不冷吗？真令人羡慕……#$b#入冬要怎么度过更好呢？$1",
  "Dialogue.Yolello.fall_Tue6": "已经开始丰收了对吧？在这个季节也只有这个会令人心动些了。",
  "Dialogue.Yolello.fall_Wed8": "我并没有忽视你的存在，只是我很冷，估计再过几日就要下雪了。",
  "Dialogue.Yolello.fall_Thu8": "……#$b#到底有多少人对你说过我怕冷？#$b#什么，是AMELE前辈说的？那没事了。$1",
  "Dialogue.Yolello.fall_Fri8": "我可没有什么好体质，哪怕是秋冬的骑士训练我都是能逃就逃的#$b#参加了训练也未必就能抗冻。$1",
  "Dialogue.Yolello.fall_Sat10": "不要因为好奇而品尝空有外表华丽的酒，那可能不是什么好东西。$1#$b#只注重与外表华丽的昂贵酒液那是供贵族收藏在展柜的，味道好不到哪里去。",
  "Dialogue.Yolello.fall_Sun10": "感觉马上就要入冬了，就算你体质再怎么好也还是多穿一些吧？$1#$b#冬日也能减少一些忙碌，但也不要因此变成闲人。",
  /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
  //[Yolello Dialogue] Winter
  "Dialogue.Yolello.winter_Mon2": "我们没有交谈的必要，找别人聊天去。",
  "Dialogue.Yolello.winter_Tue2": "我没力气和你进行交谈，我更想去喝杯热茶。",
  "Dialogue.Yolello.winter_Wed2": "我的大脑感觉不能思考事情了……这可不是什么好事。#$b#但愿我不会在这种季节遇到什么与商业相关的困惑。",
  "Dialogue.Yolello.winter_Thu4": "餐吧有炉子可以烤火？那可真是一个好地方。$1#$b#热汤也会没问题的对吧？",
  "Dialogue.Yolello.winter_Fri4": "你已经打过招呼了，就快些离开吧？#$b#不要再继续交谈下去了。",
  "Dialogue.Yolello.winter_Sat4": "山上有一处温泉对吧？#$b#我有可能会在那里待上一天。$1",
  "Dialogue.Yolello.winter_Sun6": "在这样的冬季还是在火炉旁拿着热茶度过一整天吧。",
  "Dialogue.Yolello.winter_Mon6": "我没有与你进行长时间聊天的那个精神状况，打了招呼就请离开。",
  "Dialogue.Yolello.winter_Tue6": "再待在这里我就要渡河了……#$b#嗯?我想这并不是玩笑话，我已经看见河对面有人向我招手了。",
  "Dialogue.Yolello.winter_Wed8": "我是骑士，这点毋庸置疑，没有任何能让你怀疑身份的地方。#$b#好吧，我确实不如AMELE前辈那般有良好的礼仪态度，毕竟前辈在外人面前总是完美的。$1",
  "Dialogue.Yolello.winter_Thu8": "这样的天气减少对话次数不是更好吗？在某些方面交谈也挺浪费体力的。",
  "Dialogue.Yolello.winter_Fri8": "河旁边的那位女士请我喝了热茶，我现在感觉还不错。#$b#现在我们或许能聊点什么？$1",
  "Dialogue.Yolello.winter_Sat10": "我应该去联系我的内政官将我家族所剩的任务帮我完成。#$b#可以的话真不想交给外人干这个，幸好只是一些小事情。$1",
  "Dialogue.Yolello.winter_Sun10": "这里人倒是热情的让人烦躁……#$b#我没有说这不好的意思，太过于冷漠就会失了人情味。$1"
  /*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
  /*-----------------------------------------------------------------------------------------------------------*/
}